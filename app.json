{
  "expo": {
    "name": "Organ Donation & Lifesaving Finder",
    "slug": "organ-donation-lifesaving-finder",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C62828"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lifelink.organfinder",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby donors, hospitals, and blood banks during emergencies."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#C62828"
      },
      "package": "com.lifelink.organfinder",
      "versionCode": 2,
      "softwareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Organ Donation Finder to use your location for emergency services."
        }
      ],
      "expo-asset"
    ],
    "scheme": "lifelink",
    "extra": {
      "eas": {
        "projectId": "8bab9851-be36-48c1-8a8a-73eb111c93c9"
      }
    },
    "owner": "ashok25"
  }
}
